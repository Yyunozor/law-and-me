# ─── Open Justice API ─────────────────────────────────────────────────────────
# Copier ces variables dans les Secrets de Replit (icône 🔒 dans la sidebar)
# Ne jamais committer la vraie clé dans le code !

# Clé API privée Open Justice (générée dans ton compte)
VITE_OPENJUSTICE_API_KEY=nap_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL de base de l'API Open Justice
# TODO: vérifier l'endpoint exact dans la doc / settings de ton compte
VITE_OPENJUSTICE_API_URL=https://openjustice.ai/api/v1

# ─── Replit (déjà fournis automatiquement) ────────────────────────────────────
PORT=3000
BASE_PATH=/
